@{
    ViewData["Title"] = "Home Page";
    var empCode = Context.Session.GetString("EmpCode");
    var empName = Context.Session.GetString("EmpName");
}

<style>
    .home-container {
        padding: 30px 20px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
    }

    .home-content {
        max-width: 1200px;
        margin: 0 auto;
        background: white;
        padding: 40px;
        border-radius: 10px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.2);
    }

    .welcome-header {
        text-align: center;
        margin-bottom: 40px;
        color: #2c3e50;
    }

    .welcome-header h1 {
        font-size: 32px;
        margin-bottom: 10px;
    }

    .user-info {
        background-color: #ecf0f1;
        padding: 15px;
        border-left: 4px solid #3498db;
        margin-bottom: 30px;
        border-radius: 5px;
    }

    .user-info p {
        margin: 8px 0;
        font-size: 16px;
        color: #2c3e50;
    }

    .menu-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
    }

    .menu-card {
        background: white;
        border: 2px solid #ecf0f1;
        border-radius: 8px;
        padding: 20px;
        text-align: center;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .menu-card:hover {
        border-color: #3498db;
        box-shadow: 0 8px 20px rgba(52, 152, 219, 0.3);
        transform: translateY(-5px);
    }

    .menu-card a {
        text-decoration: none;
        color: inherit;
        display: block;
    }

    .menu-card-icon {
        font-size: 40px;
        margin-bottom: 15px;
    }

    .menu-card-title {
        font-size: 18px;
        font-weight: bold;
        color: #2c3e50;
        margin-bottom: 10px;
    }

    .menu-card-description {
        font-size: 14px;
        color: #7f8c8d;
    }

    .logout-container {
        display: flex;
        justify-content: center;
        gap: 10px;
        margin-top: 40px;
    }

    .logout-btn {
        background-color: #e74c3c;
        color: white;
        padding: 12px 30px;
        border: none;
        border-radius: 5px;
        cursor: pointer;
        font-size: 16px;
        font-weight: bold;
        transition: background-color 0.3s;
    }

    .logout-btn:hover {
        background-color: #c0392b;
    }
</style>

<div class="home-container">
    <div class="home-content">
        <div class="welcome-header">
            <h1>Welcome to HR Management System</h1>
            <p>Manage your HR operations efficiently</p>
        </div>

        @if (!string.IsNullOrEmpty(empCode))
        {
            <div class="user-info">
                <p><strong>Employee Code:</strong> @empCode</p>
                <p><strong>Employee Name:</strong> @empName</p>
            </div>
        }

        <div class="menu-grid">
            <div class="menu-card">
                <a href="/EmpMaster/AddEmployee">
                    <div class="menu-card-icon">👤</div>
                    <div class="menu-card-title">Add Employee</div>
                    <div class="menu-card-description">Create a new employee record</div>
                </a>
            </div>

            <div class="menu-card">
                <a href="/EmpMaster/EmployeesList">
                    <div class="menu-card-icon">👥</div>
                    <div class="menu-card-title">Employees List</div>
                    <div class="menu-card-description">View all employees</div>
                </a>
            </div>

            <div class="menu-card">
                <a href="/Department/Index">
                    <div class="menu-card-icon">🏢</div>
                    <div class="menu-card-title">Department Master</div>
                    <div class="menu-card-description">Manage departments</div>
                </a>
            </div>
        </div>

        <div class="logout-container">
            <a href="/LoginUser/Logout" class="logout-btn">Sign Out</a>
        </div>
    </div>
</div>
